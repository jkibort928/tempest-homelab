[Unit]
Description=Prowlarr Indexer
After=network-online.target
StartLimitBurst=5
StartLimitIntervalSec=60

[Container]
ContainerName=prowlarr
Image=lscr.io/linuxserver/prowlarr:latest
AutoUpdate=registry
Memory=256M

Environment=PUID=0
Environment=PGID=0

Volume=%h/srv/@media/config/prowlarr:/config:Z
Network=media-internal.network
PublishPort=9696:9696

Volume=/etc/localtime:/etc/localtime:ro

[Install]
WantedBy=default.target

[Service]
CPUWeight=50
Restart=on-failure
RestartSec=5
