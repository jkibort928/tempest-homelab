/*
    Optionals Legend:
        '*#' = prospective   (useful but unneeded atm, install when needed)
        '?#' = optional      (probably don't need this)
        '!#' = unneeded      (don't need this)
*/

<essential>
    git
    tmux
    curl
</essential>

<deps>
    <ghcup>
        gcc
        gcc-c++
        gmp
        gmp-devel
        make
        ncurses 
        ncurses-compat-libs
        xz
        perl
    </ghcup>
</deps>

<tools>
    btop
</tools>
